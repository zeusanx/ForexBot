<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#131722">

    <!-- Top toolbar — like TradingView header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0D1117"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="←"
            android:textSize="18sp"
            android:textColor="#787B86"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"/>

        <!-- Symbol + timeframe -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EUR/USD"
                android:textColor="#D1D4DC"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M5  ·  EMA(9) + EMA(21)"
                android:textColor="#787B86"
                android:textSize="10sp"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="↺"
            android:textSize="17sp"
            android:textColor="#787B86"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"/>

    </LinearLayout>

    <!-- OHLC info bar — like TradingView candle info strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:background="#1A1F2E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O "
            android:textColor="#787B86"
            android:textSize="10sp"/>
        <TextView
            android:id="@+id/tv_ohlc_open"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#D1D4DC"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H "
            android:textColor="#787B86"
            android:textSize="10sp"/>
        <TextView
            android:id="@+id/tv_ohlc_high"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#26A69A"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L "
            android:textColor="#787B86"
            android:textSize="10sp"/>
        <TextView
            android:id="@+id/tv_ohlc_low"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#EF5350"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="C "
            android:textColor="#787B86"
            android:textSize="10sp"/>
        <TextView
            android:id="@+id/tv_ohlc_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#D1D4DC"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- MAIN CHART — takes most of the screen, like TradingView -->
    <com.github.mikephil.charting.charts.CombinedChart
        android:id="@+id/candlestick_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#131722"/>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E2433"/>

    <!-- BOT TRADES panel — compact list at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1117"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOT TRADES"
            android:textColor="#787B86"
            android:textSize="10sp"
            android:letterSpacing="0.1"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chart_trades"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#131722"
        android:paddingHorizontal="6dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"/>

</LinearLayout>