<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/mt5_bg" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="28dp" android:gravity="center">

        <!-- Logo / Brand -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ForexBot" android:textColor="@color/mt5_green"
            android:textSize="34sp" android:fontFamily="sans-serif-medium"
            android:layout_marginTop="60dp" android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Automated EMA Trading" android:textColor="@color/mt5_text_sec"
            android:textSize="13sp" android:layout_marginBottom="48dp"/>

        <!-- Title -->
        <TextView android:id="@+id/tv_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Welcome Back" android:textColor="@color/mt5_text"
            android:textSize="22sp" android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp"/>
        <TextView android:id="@+id/tv_subtitle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Sign in to your trading account"
            android:textColor="@color/mt5_text_sec" android:textSize="13sp"
            android:layout_marginBottom="28dp"/>

        <!-- Name field (register only) -->
        <LinearLayout android:id="@+id/layout_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Full Name" android:textColor="@color/mt5_text_sec"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/et_name"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:hint="Enter your name" android:textColor="@color/mt5_text"
                android:textColorHint="@color/mt5_text_sec"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:inputType="textPersonName"/>
        </LinearLayout>

        <!-- Email -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Email" android:textColor="@color/mt5_text_sec"
            android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_email"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="trader@example.com" android:textColor="@color/mt5_text"
            android:textColorHint="@color/mt5_text_sec"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="textEmailAddress" android:layout_marginBottom="12dp"/>

        <!-- Password -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Password" android:textColor="@color/mt5_text_sec"
            android:textSize="12sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_password"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="••••••••" android:textColor="@color/mt5_text"
            android:textColorHint="@color/mt5_text_sec"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="textPassword" android:layout_marginBottom="24dp"/>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:text="SIGN IN" android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/mt5_green" app:cornerRadius="8dp"
            android:textColor="#FFFFFF" android:layout_marginBottom="20dp"/>

        <!-- Toggle -->
        <TextView android:id="@+id/tv_toggle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Don't have an account? Create one"
            android:textColor="@color/mt5_blue" android:textSize="13sp"
            android:padding="8dp"/>

    </LinearLayout>
</ScrollView>