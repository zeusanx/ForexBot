<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/mt5_bg">

    <!-- MT5-style Top Header Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@color/mt5_header" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">

        <!-- App Brand -->
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="ForexBot"
            android:textColor="@color/mt5_green" android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- EURUSD live tick area -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="EUR/USD" android:textColor="@color/mt5_text_sec"
                android:textSize="11sp" android:layout_marginEnd="6dp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BID" android:textColor="@color/mt5_text_sec" android:textSize="9sp"/>
                <TextView android:id="@+id/tv_bid"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1.08500" android:textColor="@color/mt5_red"
                    android:textSize="13sp" android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ASK" android:textColor="@color/mt5_text_sec" android:textSize="9sp"/>
                <TextView android:id="@+id/tv_ask"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1.08520" android:textColor="@color/mt5_green"
                    android:textSize="13sp" android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- spread label (invisible placeholder) -->
            <TextView android:id="@+id/tv_spread"
                android:layout_width="0dp" android:layout_height="0dp" android:text=""/>

        </LinearLayout>

        <!-- User avatar -->
        <TextView android:id="@+id/tv_user_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="T" android:textColor="@color/mt5_green" android:textSize="13sp"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <!-- Fragment content -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"/>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/mt5_header"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>